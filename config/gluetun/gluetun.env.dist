# Gluetun VPN configuration
# Copy this file to gluetun.env and fill in your provider credentials.
# Full list of supported providers and their required variables:
# https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers

# Required: VPN service provider (e.g. mullvad, nordvpn, expressvpn, protonvpn, custom, ...)
VPN_SERVICE_PROVIDER=mullvad

# Required: VPN type (openvpn or wireguard, depending on your provider)
VPN_TYPE=wireguard

# --- WireGuard example (Mullvad) ---
# WIREGUARD_PRIVATE_KEY=your_private_key
# WIREGUARD_ADDRESSES=10.x.x.x/32
# SERVER_COUNTRIES=Netherlands

# --- OpenVPN example ---
# OPENVPN_USER=your_username
# OPENVPN_PASSWORD=your_password
# SERVER_COUNTRIES=Netherlands
# OPENVPN_CUSTOM_CONFIG=/gluetun/custom/openvpn.ovpn

# Optional: enforce encrypted upstream DNS transport
# DNS_UPSTREAM_RESOLVER_TYPE=DoT
# DNS_UPSTREAM_RESOLVERS=cloudflare
# DNS_KEEP_NAMESERVER=off

# Optional: firewall outbound subnets to allow LAN access for health checks
# FIREWALL_OUTBOUND_SUBNETS=172.30.11.0/24

# Optional: allow incoming peer connections from VPN interface (improves qBittorrent reachability)
# FIREWALL_VPN_INPUT_PORTS=6881
