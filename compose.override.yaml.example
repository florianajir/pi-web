# Hardware acceleration for immich-server.
#
# Copy this file to compose.override.yaml (gitignored) and uncomment the
# section matching your hardware. Docker Compose merges it automatically.
#
# After starting, configure Immich: Administration → Transcoding Settings
#   - Hardware acceleration: V4L2 (RPi) or VAAPI (x86/Intel/AMD)
#   - Preset: ultrafast  |  CRF: 28  |  Policy: Required codecs
#
# Find your video group GID: getent group video | cut -d: -f3

services:
  immich-server:

    # -------------------------------------------------------------------------
    # Raspberry Pi 5 — HEVC hardware decoder (rpi-hevc-dec)
    # -------------------------------------------------------------------------
    # devices:
    #   - /dev/video19:/dev/video19
    #   - /dev/media1:/dev/media1
    # group_add:
    #   - "44"  # video GID

    # -------------------------------------------------------------------------
    # Raspberry Pi 4 — H.264 hardware encoder+decoder (bcm2835-codec)
    # -------------------------------------------------------------------------
    # devices:
    #   - /dev/video10:/dev/video10
    #   - /dev/video11:/dev/video11
    #   - /dev/video12:/dev/video12
    #   - /dev/media2:/dev/media2
    # group_add:
    #   - "44"  # video GID

    # -------------------------------------------------------------------------
    # x86 — Intel / AMD VAAPI
    # -------------------------------------------------------------------------
    # devices:
    #   - /dev/dri/renderD128:/dev/dri/renderD128
    # group_add:
    #   - "109"  # render GID — verify with: getent group render | cut -d: -f3

    # -------------------------------------------------------------------------
    # NVIDIA — requires nvidia-container-toolkit on the host
    # -------------------------------------------------------------------------
    # deploy:
    #   resources:
    #     reservations:
    #       devices:
    #         - driver: nvidia
    #           count: 1
    #           capabilities: [gpu]
